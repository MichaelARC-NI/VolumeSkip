<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0208">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="VolumeSkip"
            android:textColor="#ffd700"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:shadowColor="#ffd700"
            android:shadowRadius="15"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Control musical al estilo Motorola"
            android:textColor="#a0848f"
            android:textSize="12sp"
            android:fontFamily="serif"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/titleText" />

        <!-- Estado Servicio -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="○ Servicio: INACTIVO"
            android:textColor="#a0848f"
            android:textSize="15sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitleText" />

        <Button
            android:id="@+id/btnToggle"
            android:layout_width="250dp"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:background="#ffd700"
            android:text="▶ ACTIVAR SERVICIO"
            android:textColor="#0d0208"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/statusText" />

        <!-- Estado Accesibilidad -->
        <TextView
            android:id="@+id/accessibilityStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="○ Accesibilidad: INACTIVA"
            android:textColor="#a0848f"
            android:textSize="14sp"
            android:fontFamily="serif"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnToggle" />

        <Button
            android:id="@+id/btnAccessibility"
            android:layout_width="250dp"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:background="#ff4d6d"
            android:text="⚙ ACTIVAR ACCESIBILIDAD"
            android:textColor="#ffffff"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/accessibilityStatus" />

        <!-- Switch desactivar -->
        <TextView
            android:id="@+id/switchLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="🔄 Interruptor rápido"
            android:textColor="#3a2a30"
            android:textSize="11sp"
            android:fontFamily="serif"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnAccessibility" />

        <Switch
            android:id="@+id/switchDisable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Desactivar VolumeSkip"
            android:textColor="#a0848f"
            android:textSize="13sp"
            android:fontFamily="serif"
            android:thumbTint="#ffd700"
            android:trackTint="#2a1a20"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/switchLabel" />

        <TextView
            android:id="@+id/switchHint"
            android:layout_width="0dp"
            android:layout_marginHorizontal="30dp"
            android:layout_height="wrap_content"
            android:text="Al desactivar, las teclas de volumen vuelven a su función normal"
            android:textColor="#3a2a30"
            android:textSize="10sp"
            android:fontFamily="serif"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/switchDisable" />

        <!-- Instrucciones -->
        <View
            android:id="@+id/divider1"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginHorizontal="35dp"
            android:layout_marginTop="12dp"
            android:background="#2a1a20"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/switchHint" />

        <TextView
            android:id="@+id/instructionsText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:layout_marginTop="10dp"
            android:text="✦ PRESIÓN CORTA → Volumen\n✦ MANTENER VOL+ → Siguiente\n✦ MANTENER VOL- → Retroceder\n✦ Funciona en 2do plano y pantalla apagada"
            android:textColor="#5a4a50"
            android:textSize="12sp"
            android:fontFamily="serif"
            android:lineSpacingExtra="4dp"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider1" />

        <!-- Botones de prueba -->
        <View
            android:id="@+id/divider2"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginHorizontal="35dp"
            android:layout_marginTop="10dp"
            android:background="#2a1a20"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/instructionsText" />

        <TextView
            android:id="@+id/testLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="PRUEBA"
            android:textColor="#3a2a30"
            android:textSize="10sp"
            android:fontFamily="serif"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider2" />

        <Button
            android:id="@+id/btnTestPrev"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="5dp"
            android:layout_marginTop="6dp"
            android:text="⏮ Anterior"
            android:textColor="#0d0208"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#a0848f"
            app:layout_constraintEnd_toStartOf="@id/btnTestNext"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/testLabel" />

        <Button
            android:id="@+id/btnTestNext"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="30dp"
            android:layout_marginTop="6dp"
            android:text="⏭ Siguiente"
            android:textColor="#0d0208"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#a0848f"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnTestPrev"
            app:layout_constraintTop_toBottomOf="@id/testLabel" />

        <!-- Redes Sociales -->
        <View
            android:id="@+id/divider3"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginHorizontal="35dp"
            android:layout_marginTop="14dp"
            android:background="#2a1a20"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnTestNext" />

        <TextView
            android:id="@+id/socialLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Michael Antonio Rodríguez Condega"
            android:textColor="#ffd700"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:shadowColor="#ffd700"
            android:shadowRadius="5"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider3" />

        <TextView
            android:id="@+id/socialSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="androidmovil@proton.me"
            android:textColor="#5a4a50"
            android:textSize="9sp"
            android:fontFamily="serif"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/socialLabel" />

        <Button
            android:id="@+id/btnFacebook"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="5dp"
            android:layout_marginTop="6dp"
            android:text="f Facebook"
            android:textColor="#ffffff"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#1877F2"
            app:layout_constraintEnd_toStartOf="@id/btnTelegram"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/socialSub" />

        <Button
            android:id="@+id/btnTelegram"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:layout_marginTop="6dp"
            android:text="✈ Telegram"
            android:textColor="#ffffff"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#0088cc"
            app:layout_constraintEnd_toStartOf="@id/btnWhatsApp"
            app:layout_constraintStart_toEndOf="@id/btnFacebook"
            app:layout_constraintTop_toBottomOf="@id/socialSub" />

        <Button
            android:id="@+id/btnWhatsApp"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="6dp"
            android:text="💬 WhatsApp"
            android:textColor="#ffffff"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#25D366"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnTelegram"
            app:layout_constraintTop_toBottomOf="@id/socialSub" />

        <Button
            android:id="@+id/btnYouTube"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginHorizontal="70dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="20dp"
            android:text="▶ YouTube"
            android:textColor="#ffffff"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#FF0000"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnFacebook"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
