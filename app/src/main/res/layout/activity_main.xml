<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0208">

    <!-- Título -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:text="VolumeSkip"
        android:textColor="#ffd700"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:shadowColor="#ffd700"
        android:shadowRadius="15"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Subtítulo -->
    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Control musical al estilo Motorola"
        android:textColor="#a0848f"
        android:textSize="14sp"
        android:fontFamily="serif"
        android:letterSpacing="0.08"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleText" />

    <!-- Estado -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="○  INACTIVO"
        android:textColor="#a0848f"
        android:textSize="20sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitleText" />

    <!-- Botón principal -->
    <Button
        android:id="@+id/btnToggle"
        android:layout_width="260dp"
        android:layout_height="56dp"
        android:layout_marginTop="30dp"
        android:background="#ffd700"
        android:text="▶  ACTIVAR"
        android:textColor="#0d0208"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:shadowColor="#ffd700"
        android:shadowRadius="5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusText" />

    <!-- Instrucciones -->
    <TextView
        android:id="@+id/instructionsText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="30dp"
        android:text="✦ Mantén VOL + para SIGUIENTE canción\n✦ Mantén VOL - para CANCIÓN ANTERIOR\n✦ Presión corta = volumen normal"
        android:textColor="#5a4a50"
        android:textSize="14sp"
        android:fontFamily="serif"
        android:lineSpacingExtra="6dp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnToggle" />

    <!-- Línea divisoria -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginHorizontal="50dp"
        android:layout_marginTop="25dp"
        android:background="#2a1a20"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/instructionsText" />

    <!-- Botones de prueba -->
    <TextView
        android:id="@+id/testLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="PRUEBA RÁPIDA"
        android:textColor="#3a2a30"
        android:textSize="11sp"
        android:letterSpacing="0.15"
        android:fontFamily="serif"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider" />

    <Button
        android:id="@+id/btnTestPrev"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="12dp"
        android:text="⏮ Anterior"
        android:textColor="#0d0208"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="#a0848f"
        app:layout_constraintEnd_toStartOf="@id/btnTestNext"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/testLabel" />

    <Button
        android:id="@+id/btnTestNext"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="12dp"
        android:text="⏭ Siguiente"
        android:textColor="#0d0208"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="#a0848f"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnTestPrev"
        app:layout_constraintTop_toBottomOf="@id/testLabel" />

    <!-- Firma -->
    <TextView
        android:id="@+id/firmaText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="Michael Antonio Rodríguez Condega"
        android:textColor="#1a1015"
        android:textSize="11sp"
        android:fontFamily="serif"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
